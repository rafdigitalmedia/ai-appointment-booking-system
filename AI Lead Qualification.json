    {
      "parameters": {
        "jsCode": "// Get events from Get many events node\nconst events = $('Check Calendar Availability').all();\n\n// Check if events actually have real data\nlet realEventCount = 0;\n\nfor (const event of events) {\n  // Only count if it has actual event ID (not empty object)\n  if (event.json && event.json.id && event.json.id !== '') {\n    realEventCount++;\n  }\n}\n\n// Get appointment data from earlier nodes\nconst appointmentData = $('Process Appointment Data').first().json;\n\nreturn [{ \n  json: { \n    ...appointmentData,\n    eventCount: realEventCount,\n    isSlotAvailable: realEventCount === 0\n  } \n}];"
      },
