        "messages": {
          "values": [
            {
              "content": "=Analyze this appointment request and extract structured information:\n\nREQUEST DETAILS:\n- Name: {{ $json[\"Full Name\"] }}\n- Email: {{ $json[\"Email\"] }}\n- Phone: {{ $json[\"Phone\"] }}\n- Service Type: {{ $json[\"Service Type\"] }}\n- Requested Date: {{ $json[\"Requested Date\"] }}\n- Requested Time: {{ $json[\"Requested Time\"] }}\n- Time Zone: {{ $json[\"Time Zone\"] }}\n- Message: {{ $json[\"Message\"] }}\n\nTASK:\n1. Extract and validate all contact information\n2. Identify service type and duration needed:\n   - Consultation: 30 minutes\n   - Demo: 45 minutes\n   - Strategy Call: 60 minutes\n   - Meeting: 90 minutes\n3. Assess urgency level (High/Medium/Low) based on message\n4. Parse requested date/time and convert to 24-hour format\n5. Identify any special requirements or notes\n6. Check if all required information is present\n\nRETURN as JSON:\n{\n  \"clientName\": \"string\",\n  \"email\": \"string\",\n  \"phone\": \"string\",\n  \"serviceType\": \"string\",\n  \"duration\": \"number (minutes)\",\n  \"requestedDate\": \"YYYY-MM-DD\",\n  \"requestedTime\": \"HH:MM (24-hour format)\",\n  \"timeZone\": \"string\",\n  \"urgency\": \"High|Medium|Low\",\n  \"specialRequirements\": \"string\",\n  \"hasAllInfo\": \"boolean\",\n  \"missingFields\": [\"array of missing fields\"]\n}\n\nONLY return the JSON object, no explanations."
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [
        528,
        -336
      ],
      "id": "00a2a36e-ab89-470b-b6be-d02b4083f5cf",
      "name": "AI Analysis",
      "credentials": {
        "googlePalmApi": {
          "id": null,
          "name": "",
          "__aiGatewayManaged": true
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse AI output from previous node\nconst inputData = $input.first().json;\nlet aiAnalysis = {};\n\n// Try to parse AI response (it might be in different formats)\nif (inputData.content && inputData.content.parts && inputData.content.parts[0]) {\n  const textContent = inputData.content.parts[0].text;\n  try {\n    // Remove markdown code blocks if present\n    const cleanText = textContent.replace(/```json/g, '').replace(/```/g, '').trim();\n    aiAnalysis = JSON.parse(cleanText);\n  } catch (e) {\n    // If parsing fails, use the raw content\n    aiAnalysis = inputData;\n  }\n} else {\n  aiAnalysis = inputData;\n}\n\n// Extract date and time\nconst requestedDate = aiAnalysis.requestedDate || '2026-07-25';\nconst requestedTime = aiAnalysis.requestedTime || '14:00';\nconst timeZone = aiAnalysis.timeZone || 'EST';\nconst duration = aiAnalysis.duration || 30;\n\n// Create datetime object\nconst appointmentDateTime = new Date(`${requestedDate}T${requestedTime}`);\n\n// Check business hours (9 AM - 6 PM)\nconst hour = appointmentDateTime.getHours();\nconst dayOfWeek = appointmentDateTime.getDay();\n\nconst isBusinessHours = hour >= 9 && hour < 18;\nconst isWeekend = dayOfWeek === 0 || dayOfWeek === 6; // Sunday or Saturday\n\n// Calculate buffer time (15 minutes before and after)\nconst bufferBefore = new Date(appointmentDateTime.getTime() - 15 * 60000);\nconst bufferAfter = new Date(appointmentDateTime.getTime() + duration * 60000 + 15 * 60000);\n\n// Generate 3 alternative time slots (next available business days)\nconst alternatives = [];\nlet checkDate = new Date(appointmentDateTime);\n\nfor (let i = 1; i <= 7 && alternatives.length < 3; i++) {\n  checkDate.setDate(checkDate.getDate() + 1);\n  \n  // Skip weekends\n  if (checkDate.getDay() === 0 || checkDate.getDay() === 6) continue;\n  \n  // Add 10 AM, 2 PM, 4 PM slots\n  const slot1 = new Date(checkDate);\n  slot1.setHours(10, 0, 0, 0);\n  alternatives.push(slot1.toISOString());\n  \n  if (alternatives.length < 3) {\n    const slot2 = new Date(checkDate);\n    slot2.setHours(14, 0, 0, 0);\n    alternatives.push(slot2.toISOString());\n  }\n  \n  if (alternatives.length < 3) {\n    const slot3 = new Date(checkDate);\n    slot3.setHours(16, 0, 0, 0);\n    alternatives.push(slot3.toISOString());\n  }\n}\n\n// Return processed data\nreturn {\n  json: {\n    ...aiAnalysis,\n    appointmentDateTime: appointmentDateTime.toISOString(),\n    bufferBefore: bufferBefore.toISOString(),\n    bufferAfter: bufferAfter.toISOString(),\n    isBusinessHours,\n    isWeekend,\n    alternativeSlots: alternatives.slice(0, 3),\n    status: 'processing',\n    originalInput: $input.first().json\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
